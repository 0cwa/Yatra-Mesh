                  },
                  {
                    "tagName": "div",
                    "classes": [
                      "help-content"
                    ],
                    "components": [
                      {
                        "id": "what-is-columba",
                        "tagName": "section",
                        "components": [
                          {
                            "tagName": "h2",
                            "classes": [
                              "gjs-t-h2"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "What is Columba?"
                              }
                            ]
                          },
                          {
                            "tagName": "p",
                            "classes": [
                              "gjs-t-body"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Columba is a free, open-source Android messaging app for Reticulum mesh networks. It enables communication without internet, cell towers, or central servers - using Bluetooth LE, WiFi, or LoRa radio via RNode."
                              }
                            ]
                          },
                          {
                            "tagName": "p",
                            "classes": [
                              "gjs-t-body"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Built with Material Design 3, Columba provides a clean interface for sending LXMF messages, making voice calls via LXST, and sharing location data - all with end-to-end encryption and no accounts required."
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "id": "getting-started",
                        "tagName": "section",
                        "components": [
                          {
                            "tagName": "h2",
                            "classes": [
                              "gjs-t-h2"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Getting Started"
                              }
                            ]
                          },
                          {
                            "tagName": "ol",
                            "classes": [
                              "step-list"
                            ],
                            "components": [
                              {
                                "tagName": "li",
                                "components": [
                                  {
                                    "tagName": "p",
                                    "components": [
                                      {
                                        "type": "textnode",
                                        "content": "Download the latest APK from the releases page or via Obtainium"
                                      }
                                    ]
                                  }
                                ]
                              },
                              {
                                "tagName": "li",
                                "components": [
                                  {
                                    "tagName": "p",
                                    "components": [
                                      {
                                        "type": "textnode",
                                        "content": "Install the APK (enable 'Install from unknown sources' in settings)"
                                      }
                                    ]
                                  }
                                ]
                              },
                              {
                                "tagName": "li",
                                "components": [
                                  {
                                    "tagName": "p",
                                    "components": [
                                      {
                                        "type": "textnode",
                                        "content": "Launch Columba and complete the onboarding flow"
                                      }
                                    ]
                                  }
                                ]
                              },
                              {
                                "tagName": "li",
                                "components": [
                                  {
                                    "tagName": "p",
                                    "components": [
                                      {
                                        "type": "textnode",
                                        "content": "Your identity is generated locally - no signup required"
                                      }
                                    ]
                                  }
                                ]
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "id": "communication-modes",
                        "tagName": "section",
                        "components": [
                          {
                            "tagName": "h2",
                            "classes": [
                              "gjs-t-h2"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Communication Modes"
                              }
                            ]
                          },
                          {
                            "tagName": "h3",
                            "classes": [
                              "gjs-t-h2"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Text Messaging (LXMF)"
                              }
                            ]
                          },
                          {
                            "tagName": "p",
                            "classes": [
                              "gjs-t-body"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "LXMF (Lightweight Extensible Message Format) is the primary messaging protocol. Messages are end-to-end encrypted and can be stored at Propagation Nodes for later delivery if the recipient is offline."
                              }
                            ]
                          },
                          {
                            "tagName": "h3",
                            "classes": [
                              "gjs-t-h2"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Voice Calls (LXST)"
                              }
                            ]
                          },
                          {
                            "tagName": "p",
                            "classes": [
                              "gjs-t-body"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "LXST (Lightweight Extensible Signal Transport) enables voice calls over mesh networks. Uses low-bandwidth codec2 for LoRa-friendly audio."
                              }
                            ]
                          },
                          {
                            "tagName": "h3",
                            "classes": [
                              "gjs-t-h2"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Location Sharing"
                              }
                            ]
                          },
                          {
                            "tagName": "p",
                            "classes": [
                              "gjs-t-body"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Share your GPS coordinates via LXMF messages. Recipients can view locations on an integrated map."
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "id": "contacts-tab",
                        "tagName": "section",
                        "components": [
                          {
                            "tagName": "h2",
                            "classes": [
                              "gjs-t-h2"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Contacts Tab"
                              }
                            ]
                          },
                          {
                            "tagName": "h3",
                            "classes": [
                              "gjs-t-h2"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "My Contacts"
                              }
                            ]
                          },
                          {
                            "tagName": "p",
                            "classes": [
                              "gjs-t-body"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Add contacts by scanning their Columba QR code, tapping the star icon in a conversation, or manually entering their LXMF destination hash."
                              }
                            ]
                          },
                          {
                            "tagName": "h3",
                            "classes": [
                              "gjs-t-h2"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Network Tab"
                              }
                            ]
                          },
                          {
                            "tagName": "p",
                            "classes": [
                              "gjs-t-body"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Shows all Reticulum Announces on your network. Filter by: Peers, Relays (Propagation Nodes), or Audio devices."
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "id": "network-interfaces",
                        "tagName": "section",
                        "components": [
                          {
                            "tagName": "h2",
                            "classes": [
                              "gjs-t-h2"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Network Interfaces"
                              }
                            ]
                          },
                          {
                            "tagName": "h3",
                            "classes": [
                              "gjs-t-h2"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Bluetooth LE (BLE)"
                              }
                            ]
                          },
                          {
                            "tagName": "p",
                            "classes": [
                              "gjs-t-body"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Connect to nearby Android/Linux devices. Enable in Settings > Interfaces > Bluetooth LE. Works without internet."
                              }
                            ]
                          },
                          {
                            "tagName": "h3",
                            "classes": [
                              "gjs-t-h2"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "WiFi (TCP/WLAN)"
                              }
                            ]
                          },
                          {
                            "tagName": "p",
                            "classes": [
                              "gjs-t-body"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Connect via TCP to public Reticulum gateways or discover local peers on your WLAN."
                              }
                            ]
                          },
                          {
                            "tagName": "h3",
                            "classes": [
                              "gjs-t-h2"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "LoRa via RNode"
                              }
                            ]
                          },
                          {
                            "tagName": "p",
                            "classes": [
                              "gjs-t-body"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Long-range, low-power communication using LoRa radio with RNode firmware. Range depends on antenna and environment."
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "id": "identities",
                        "tagName": "section",
                        "components": [
                          {
                            "tagName": "h2",
                            "classes": [
                              "gjs-t-h2"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Managing Identities"
                              }
                            ]
                          },
                          {
                            "tagName": "p",
                            "classes": [
                              "gjs-t-body"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Your Columba identity is a public/private keypair generated locally. It serves as your LXMF destination address."
                              }
                            ]
                          },
                          {
                            "tagName": "h3",
                            "classes": [
                              "gjs-t-h2"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Export/Import Identity"
                              }
                            ]
                          },
                          {
                            "tagName": "p",
                            "classes": [
                              "gjs-t-body"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Go to Settings > Identities to export your identity as a QR code or base64 string."
                              }
                            ]
                          },
                          {
                            "tagName": "h3",
                            "classes": [
                              "gjs-t-h2"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Multiple Identities"
                              }
                            ]
                          },
                          {
                            "tagName": "p",
                            "classes": [
                              "gjs-t-body"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Columba supports multiple identities. Create new ones in Settings > Identities > Add Identity."
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "id": "location-sharing",
                        "tagName": "section",
                        "components": [
                          {
                            "tagName": "h2",
                            "classes": [
                              "gjs-t-h2"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Location Sharing"
                              }
                            ]
                          },
                          {
                            "tagName": "p",
                            "classes": [
                              "gjs-t-body"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "In any conversation, tap the location icon to share your current GPS coordinates. Recipients receive coordinates via LXMF and can view them on the integrated map."
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "id": "troubleshooting",
                        "tagName": "section",
                        "components": [
                          {
                            "tagName": "h2",
                            "classes": [
                              "gjs-t-h2"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Troubleshooting"
                              }
                            ]
                          },
                          {
                            "tagName": "h3",
                            "classes": [
                              "gjs-t-h2"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Can't see peers"
                              }
                            ]
                          },
                          {
                            "tagName": "p",
                            "classes": [
                              "gjs-t-body"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Ensure you have at least one interface enabled (BLE, WiFi, or RNode). Check that other peers have sent an Announce."
                              }
                            ]
                          },
                          {
                            "tagName": "h3",
                            "classes": [
                              "gjs-t-h2"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Messages won't send"
                              }
                            ]
                          },
                          {
                            "tagName": "p",
                            "classes": [
                              "gjs-t-body"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Verify you have network connectivity. If recipient is offline, messages are stored at your default Propagation Node."
                              }
                            ]
                          },
                          {
                            "tagName": "h3",
                            "classes": [
                              "gjs-t-h2"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Voice call fails"
                              }
                            ]
                          },
                          {
                            "tagName": "p",
                            "classes": [
                              "gjs-t-body"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Both parties must be online simultaneously. Check your interface supports sufficient bandwidth."
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        }
