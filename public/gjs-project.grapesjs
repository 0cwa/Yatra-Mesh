":"text","name":"About Paragraph","classes":["about-paragraph"],"attributes":{"id":"ioxl1"},"components":[{"type":"textnode","content":"\n  Yatra Mesh is a peer-to-peer messaging app using wifi and bluetooth to create a decentralized mesh network. All messages are end-to-end encrypted for your privacy.\n"}]},{"tagName":"ul","name":"About Feature List","classes":["about-feature-list"],"components":[{"tagName":"li","name":"About Feature Item","classes":["about-feature-item"],"components":[{"type":"image","name":"Feature Icon","resizable":{"ratioDefault":1},"classes":["feature-icon"],"attributes":{"src":"https://api.iconify.design/lucide-wifi.svg?color=white","alt":""}},{"name":"Feature Content","classes":["feature-content"],"components":[{"tagName":"span","type":"text","name":"Feature Title","classes":["feature-title"],"components":[{"type":"textnode","content":"Wifi Mesh"}]},{"tagName":"p","type":"text","name":"Feature Description","classes":["feature-description"],"components":[{"type":"textnode","content":"Connect to the local “Yatra Mesh” hotspot or ad-hoc network. Devices pass messages peer-to-peer without a central server."}]}]}]},{"tagName":"li","name":"About Feature Item","classes":["about-feature-item"],"components":[{"type":"image","name":"Feature Icon","resizable":{"ratioDefault":1},"classes":["feature-icon"],"attributes":{"src":"https://api.iconify.design/lucide-bluetooth.svg?color=white","alt":""}},{"name":"Feature Content","classes":["feature-content"],"components":[{"tagName":"span","type":"text","name":"Feature Title","classes":["feature-title"],"components":[{"type":"textnode","content":"Bluetooth Relay"}]},{"tagName":"p","type":"text","name":"Feature Description","classes":["feature-description"],"components":[{"type":"textnode","content":"When wifi isn’t available, nearby devices can hand off messages via bluetooth, extending reach through the crowd."}]}]}]},{"tagName":"li","name":"About Feature Item","classes":["about-feature-item"],"components":[{