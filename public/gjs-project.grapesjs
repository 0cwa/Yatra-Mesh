                      {
                        "id": "cli-usage",
                        "tagName": "section",
                        "components": [
                          {
                            "tagName": "h2",
                            "classes": [
                              "gjs-t-h2"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Command Line Usage"
                              }
                            ]
                          },
                          {
                            "tagName": "pre",
                            "classes": [
                              "code-block"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "python meshchat.py --help\n\nOptions:\n  --host [HOST]         Address (default: localhost)\n  --port [PORT]         Port (default: 8000)\n  --headless            Run without opening browser\n  --identity-file PATH  Use custom identity file\n  --storage-dir DIR     Storage directory"
                              }
                            ]
                          },
                          {
                            "tagName": "h3",
                            "classes": [
                              "gjs-t-h2"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Using Existing Identity"
                              }
                            ]
                          },
                          {
                            "tagName": "pre",
                            "classes": [
                              "code-block"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "# Use custom identity file\npython meshchat.py --identity-file ./my_identity\n\n# Generate new identity\npython meshchat.py --generate-identity-file ./new_identity"
                              }
                            ]
                          }
                        ]
                      }
                    ]
