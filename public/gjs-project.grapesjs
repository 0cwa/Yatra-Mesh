          "type": "data-variable"
        },
        "background": "linear-gradient(\n      135deg,\n      var(--gjs-t-color-secondary) 0%,\n      var(--gjs-t-color-primary) 50%,\n      var(--gjs-t-color-accent) 100%\n    )",
        "background-size": "300% 300%",
        "text-shadow": "0 1px 8px rgba(0, 0, 0, 0.35)",
        "box-shadow": "0 10px 24px rgba(160, 106, 255, 0.45),\n      0 0 16px rgba(71, 179, 255, 0.40),\n      0 0 24px rgba(255, 79, 163, 0.35)",
        "transition": "transform 240ms cubic-bezier(0.4, 0, 0.2, 1),\n      box-shadow 240ms cubic-bezier(0.4, 0, 0.2, 1),\n      filter 240ms cubic-bezier(0.4, 0, 0.2, 1),\n      background-position 600ms ease",
        "animation": "gradientShift 6s ease-in-out infinite"
      },
