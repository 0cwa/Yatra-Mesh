              {
                "tagName": "script",
                "name": "Schedule Logic",
                "components": [
                  {
                    "type": "textnode",
                    "content": "\n(function() {\n  const festivalStart = new Date('2026-02-27T00:00:00');\n  const festivalEnd = new Date('2026-03-02T23:59:59');\n  const today = new Date();\n  \n  let dayToOpen = 'day-1';\n  \n  if (today >= festivalEnd) {\n    dayToOpen = 'day-4';\n  } else if (today >= new Date('2026-03-01T00:00:00')) {\n    dayToOpen = 'day-3';\n  } else if (today >= new Date('2026-02-28T00:00:00')) {\n    dayToOpen = 'day-2';\n  } else if (today <= festivalStart) {\n    dayToOpen = 'day-1';\n  }\n  \n  // Close all days first\n  document.querySelectorAll('.schedule-day').forEach(d => d.removeAttribute('open'));\n  \n  // Open the correct day\n  setTimeout(() => {\n    const day = document.getElementById(dayToOpen);\n    if (day) day.setAttribute('open', '');\n  }, 100);\n})();\n      "
                  }
                ]
