                      {
                        "tagName": "section",
                        "name": "FAQ Section",
                        "classes": [
                          "faq-section"
                        ],
                        "components": [
                          {
                            "tagName": "h2",
                            "type": "heading",
                            "name": "FAQ Title",
                            "classes": [
                              "gjs-t-h2",
                              "faq-title"
                            ],
                            "attributes": {
                              "id": "i5wooj"
                            },
                            "components": [
                              {
                                "type": "textnode",
                                "content": "FAQ"
                              }
                            ]
                          },
                          {
                            "name": "FAQ Grid",
                            "classes": [
                              "faq-grid"
                            ],
                            "components": [
                              {
                                "tagName": "details",
                                "name": "FAQ Item",
                                "classes": [
                                  "group",
                                  "faq-item"
                                ],
                                "components": [
                                  {
                                    "tagName": "summary",
                                    "name": "FAQ Summary",
                                    "classes": [
                                      "faq-summary"
                                    ],
                                    "components": [
                                      {
                                        "tagName": "span",
                                        "type": "text",
                                        "name": "FAQ Question",
                                        "classes": [
                                          "faq-question"
                                        ],
                                        "components": [
                                          {
                                            "type": "textnode",
                                            "content": "How do I join the mesh?"
                                          }
                                        ]
                                      },
                                      {
                                        "type": "image",
                                        "name": "FAQ Chevron",
                                        "resizable": {
                                          "ratioDefault": 1
                                        },
                                        "classes": [
                                          "group-open:rotate-180",
                                          "faq-chevron"
                                        ],
                                        "attributes": {
                                          "src": "https://api.iconify.design/lucide-chevron-down.svg?color=white",
                                          "alt": ""
                                        }
                                      }
                                    ]
                                  },
                                  {
                                    "type": "text",
                                    "name": "FAQ Answer",
                                    "classes": [
                                      "faq-answer"
                                    ],
                                    "components": [
                                      {
                                        "type": "textnode",
                                        "content": "\n              Install the Android app, enable bluetooth and wifi, then open Yatra Mesh. If a local hotspot or ad-hoc SSID appears (e.g., \u201cYatra Mesh\u201d), connect to it. The app will announce and relay messages to nearby peers automatically.\n            "
                                      }
                                    ]
                                  }
                                ]
                              },
                              {
                                "tagName": "details",
                                "name": "FAQ Item",
                                "classes": [
                                  "group",
                                  "faq-item"
                                ],
                                "components": [
                                  {
                                    "tagName": "summary",
                                    "name": "FAQ Summary",
                                    "classes": [
                                      "faq-summary"
                                    ],
                                    "components": [
                                      {
                                        "tagName": "span",
                                        "type": "text",
                                        "name": "FAQ Question",
                                        "classes": [
                                          "faq-question"
                                        ],
                                        "components": [
                                          {
                                            "type": "textnode",
                                            "content": "Is my data private?"
                                          }
                                        ]
                                      },
                                      {
                                        "type": "image",
                                        "name": "FAQ Icon",
                                        "resizable": {
                                          "ratioDefault": 1
                                        },
                                        "classes": [
                                          "faq-icon"
                                        ],
                                        "attributes": {
                                          "src": "https://api.iconify.design/lucide-lock.svg?color=white",
                                          "alt": ""
                                        }
                                      }
                                    ]
                                  },
                                  {
                                    "type": "text",
                                    "name": "FAQ Answer",
                                    "classes": [
                                      "faq-answer"
                                    ],
                                    "components": [
                                      {
                                        "type": "textnode",
                                        "content": "\n              Messages are relayed peer-to-peer and can be end-to-end encrypted when chatting directly. In mesh relays, metadata like relay hops may be visible to participating nodes. Avoid sensitive information; this is an experimental network.\n            "
                                      }
                                    ]
                                  }
                                ]
                              },
                              {
                                "tagName": "details",
                                "name": "FAQ Item",
                                "classes": [
                                  "group",
                                  "faq-item"
                                ],
                                "components": [
                                  {
                                    "tagName": "summary",
                                    "name": "FAQ Summary",
                                    "classes": [
                                      "faq-summary"
                                    ],
                                    "components": [
                                      {
                                        "tagName": "span",
                                        "type": "text",
                                        "name": "FAQ Question",
                                        "classes": [
                                          "faq-question"
                                        ],
                                        "components": [
                                          {
                                            "type": "textnode",
                                            "content": "Why Android over desktop?"
                                          }
                                        ]
                                      },
                                      {
                                        "type": "image",
                                        "name": "FAQ Icon",
                                        "resizable": {
                                          "ratioDefault": 1
                                        },
                                        "classes": [
                                          "faq-icon"
                                        ],
                                        "attributes": {
                                          "src": "https://api.iconify.design/lucide-badge-check.svg?color=white",
                                          "alt": ""
                                        }
                                      }
                                    ]
                                  },
                                  {
                                    "type": "text",
                                    "name": "FAQ Answer",
                                    "classes": [
                                      "faq-answer"
                                    ],
                                    "components": [
                                      {
                                        "type": "textnode",
                                        "content": "\n              Android supports background scanning/relaying with better power profiles and direct bluetooth/wifi APIs. Desktop platforms require more permissions, have background limitations, and are best used as relay nodes.\n            "
                                      }
                                    ]
                                  }
                                ]
                              },
                              {
                                "tagName": "details",
                                "name": "FAQ Item",
                                "classes": [
                                  "group",
                                  "faq-item"
                                ],
                                "components": [
                                  {
                                    "tagName": "summary",
                                    "name": "FAQ Summary",
                                    "classes": [
                                      "faq-summary"
                                    ],
                                    "components": [
                                      {
                                        "tagName": "span",
                                        "type": "text",
                                        "name": "FAQ Question",
                                        "classes": [
                                          "faq-question"
                                        ],
                                        "components": [
                                          {
                                            "type": "textnode",
                                            "content": "Troubleshooting tips"
                                          }
                                        ]
                                      },
                                      {
                                        "type": "image",
                                        "name": "FAQ Icon",
                                        "resizable": {
                                          "ratioDefault": 1
                                        },
                                        "classes": [
                                          "faq-icon"
                                        ],
                                        "attributes": {
                                          "src": "https://api.iconify.design/lucide-wrench.svg?color=white",
                                          "alt": ""
                                        }
                                      }
                                    ]
                                  },
                                  {
                                    "type": "text",
                                    "name": "FAQ Answer",
                                    "classes": [
                                      "faq-answer"
                                    ],
                                    "components": [
                                      {
                                        "type": "textnode",
                                        "content": "\n              Ensure bluetooth and wifi are enabled. Keep the app in foreground when first joining. Move closer to the crowd. If you lose messages, toggle airplane mode off/on to refresh radios, or restart the app to reannounce presence.\n            "
                                      }
                                    ]
                                  }
                                ]
                              }
                            ]
                          }
                        ]
                      }
                    ]
