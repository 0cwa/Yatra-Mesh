                            "tagName": "p",
                            "classes": [
                              "gjs-t-body"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Messages are automatically encrypted end-to-end. If recipient is offline, messages are stored at your designated Propagation Node."
                              }
