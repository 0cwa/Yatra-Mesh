nnectivity across different environments."}]},{"tagName":"ul","name":"Docs List","classes":["docs-list"],"components":[{"tagName":"li","name":"Docs Item","classes":["docs-item"],"components":[{"type":"image","name":"Docs Icon","resizable":{"ratioDefault":1},"classes":["docs-icon"],"attributes":{"src":"https://api.iconify.design/lucide-file-code-2.svg?color=%23eaeaf1","alt":"Code"}},{"type":"link","name":"Docs Link","classes":["gjs-t-link","docs-link"],"attributes":{"href":"#"},"components":[{"type":"textnode","content":"Android setup guide"}]}]},{"tagName":"li","name":"Docs Item","classes":["docs-item"],"components":[{"type":"image","name":"Docs Icon","resizable":{"ratioDefault":1},"classes":["docs-icon"],"attributes":{"src":"https://api.iconify.design/lucide-wrench.svg?color=%23eaeaf1","alt":"Wrench"}},{"type":"link","name":"Docs Link","classes":["gjs-t-link","docs-link"],"attributes":{"href":"#"},"components":[{"type":"textnode","content":"Desktop troubleshooting"}]}]},{"tagName":"li","name":"Docs Item","classes":["docs-item"],"components":[{"type":"image","name":"Docs Icon","resizable":{"ratioDefault":1},"classes":["docs-icon"],"attributes":{"src":"https://api.iconify.design/lucide-radio.svg?color=%23eaeaf1","alt":"Radio"}},{"type":"link","name":"Docs Link","classes":["gjs-t-link","docs-link"],"attributes":{"href":"#"},"components":[{"type":"textnode","content":"Discovery & range tuning"}]}]}]},{"type":"image","name":"Card Image","resizable":{"ratioDefault":1},"classes":["card-image"],"attributes":{"loading":"lazy","src":"https://app.grapesjs.com/api/assets/random-image?query=%22documentation%20guide%20dark%22&w=980&h=300","alt":"Docs Visual"}}]}]}]},{"tagName":"section","name":"Information Section","classes":["information-section"],"attributes":{"id":"info"},"components":[{"name":"Info Header","classes":["info-header"],"components":[{"tagName":"h2","type":"heading","name":"Info Title","classes":["gjs-t-h2","info-title"],"components":[{"type":"textnode","content":"Information"}]},{"tagName":"span","type":"text","name":"Info Subtitle","classes":["info-subtitle"],"components":[{"type":"textnode","content":"Readability meets psychedelia"}]}]},{"name":"Info Grid","classes":["info-grid"],"components":[{"name":"Info Card","classes":["gjs-t-border","info-card"],"components":[{"name":"Card Title Row","classes":["card-title-row"],"components":[{"type":"image","name":"Card Icon","resizable":{"ratioDefault":1},"classes":["card-icon"],"attributes":{"src":"https://api.iconify.design/lucide-message-square.svg?color=%23eaeaf1","alt":"Message"}},{"tagName":"span","type":"text","name":"Card Title","classes":["card-title"],"components":[{"type":"textnode","content":"Messaging Flow"}]}]},{"tagName":"p","type":"text","name":"Card Text","classes":["card-text"],"components":[{"type":"textnode","content":"Messages are broadcast to nearby peers and relayed hop-by-hop. Delivery is opportunistic; the mesh adapts as peers join and leave. Expect occasional delays and creative paths through the crowd."}]}]},{"name":"Info Card","classes":["gjs-t-border","info-card"],"components":[{"name":"Card Title Row","classes":["card-title-row"],"components":[{"type":"image","name":"Card Icon","resizable":{"ratioDefault":1},"classes":["card-icon"],"attributes":{"src":"https://api.iconify.design/lucide-lock.svg?color=%23eaeaf1","alt":"Lock"}},{"tagName":"span","type":"text","name":"Card Title","classes":["card-title"],"components":[{"type":"textnode","content":"Privacy & Safety"}]}]},{"tagName":"p","type":"text","name":"Card Text","classes":["card-text"],"components":[{"type":"textnode","content":"Local-first means your data isn’t uploaded. However, radio signals are public by nature; avoid sharing sensitive information. Future builds may add end-to-end encryption overlays."}]}]},{"name":"Info Card","classes":["gjs-t-border","info-card"],"components":[{"name":"Card Title Row","classes":["card-title-row"],"components":[{"type":"image","name":"Card Icon","resizable":{"ratioDefault":1},"classes":["card-icon"],"attributes":{"src":"https://api.iconify.design/lucide-compass.svg?color=%23eaeaf1","alt":"Compass"}},{"tagName":"span","type":"text","name":"Card Title","classes":["card-title"],"components":[{"type":"textnode","content":"Use Cases"}]}]},{"tagName":"p","type":"text","name":"Card Text","classes":["card-text"],"components":[{"type":"textnode","content":"Pop-up festivals, workshops, impromptu campuses, or disaster scenarios—anywhere traditional connectivity is limited or you want to share presence without dependency."}]}]}]}]},{"tagName":"section","name":"FAQ Section","classes":["faq-section"],"attributes":{"id":"faq"},"components":[{"name":"FAQ Header","classes":["faq-header"],"components":[{"tagName":"h2","type":"heading","name":"FAQ Title","classes":["gjs-t-h2","faq-title"],"components":[{"type":"textnode","content":"FAQ"}]},{"type":"link","name":"FAQ Schedule Link","classes":["gjs-t-link","faq-schedule-link"],"attributes":{"href":"page://qggXCAKgYbF5MnI4M"},"components":[{"type":"image","name":"FAQ Icon","resizable":{"ratioDefault":1},"classes":["faq-icon"],"attributes":{"src":"https://api.iconify.design/lucide-calendar-days.svg?color=%2347b3ff","alt":"Calendar"}},{"type":"textnode","content":"\n        See event schedule\n      "}]}]},{"name":"FAQ List","classes":["faq-list"],"components":[{"tagName":"details","name":"FAQ Item","classes":["gjs-t-border","faq-item"],"components":[{"tagName":"summary","name":"FAQ Summary","classes":["faq-summary"],"components":[{"tagName":"span","type":"text","name":"FAQ Question","classes":["faq-question"],"components":[{"type":"textnode","content":"Is internet required to use Yatra Mesh?"}]},{"tagName":"span","type":"text","name":"FAQ Indicator","classes":["faq-indicator"],"components":[{"type":"textnode","content":"Toggle"}]}]},{"type":"text","name":"FAQ Content","classes":["faq-content"],"components":[{"type":"textnode","content":"No. It works over local WiFi and Bluetooth radios. If your device can talk to nearby peers, you can exchange messages without Internet."}]}]},{"tagName":"details","name":"FAQ Item","classes":["gjs-t-border","faq-item"],"components":[{"tagName":"summary","name":"FAQ Summary","classes":["faq-summary"],"components":[{"tagName":"span","type":"text","name":"FAQ Question","classes":["faq-question"],"components":[{"type":"textnode","content":"Which platform should I use?"}]},{"tagName":"span","type":"text","name":"FAQ Indicator","classes":["faq-indicator"],"components":[{"type":"textnode","content":"Toggle"}]}]},{"type":"text","name":"FAQ Content","classes":["faq-content"],"components":[{"type":"textnode","content":"Android is recommended for the smoothest experience. Desktop apps exist for Linux, macOS, and Windows but may have limitations depending on drivers and OS policies."}]}]},{"tagName":"details","name":"FAQ Item","classes":["gjs-t-border","faq-item"],"components":[{"tagName":"summary","name":"FAQ Summary","classes":["faq-summary"],"components":[{"tagName":"span","type":"text","name":"FAQ Question","classes":["faq-question"],"components":[{"type":"textnode","content":"How far can messages travel?"}]},{"tagName":"span","type":"text","name":"FAQ Indicator","classes":["faq-indicator"],"components":[{"type":"textnode","content":"Toggle"}]}]},{"type":"text","name":"FAQ Content","classes":["faq-content"],"components":[{"type":"textnode","content":"Range varies by hardware and environment. Messages can traverse multiple hops; the more participants, the further messages can propagate."}]}]},{"tagName":"details","name":"FAQ Item","classes":["gjs-t-border","faq-item"],"components":[{"tagName":"summary","name":"FAQ Summary","classes":["faq-summary"],"components":[{"tagName":"span","type":"text","name":"FAQ Question","classes":["faq-question"],"components":[{"type":"textnode","content":"Is my data encrypted?"}]},{"tagName":"span","type":"text","name":"FAQ Indicator","classes":["faq-indicator"],"components":[{"type":"textnode","content":"Toggle"}]}]},{"type":"text","name":"FAQ Content","classes":["faq-content"],"components":[{"type":"textnode","content":"The current experimental build focuses on connectivity and routing. Avoid sensitive content for now. Encryption overlays are planned; check the downloads page for updates."}]}]}]}]},{"tagName":"section","name":"Schedule Preview Section","classes":["schedule-preview-section"],"components":[{"name":"Preview Header","classes":["preview-header"],"components":[{"name":"Preview Title Group","classes":["preview-title-group"],"components":[{"type":"image","name":"Preview Icon","resizable":{"ratioDefault":1},"classes":["preview-icon"],"attributes":{"src":"https://api.iconify.design/lucide-calendar-days.svg?color=%23eaeaf1","alt":"Calendar"}},{"tagName":"h2","type":"heading","name":"Preview Title","classes":["gjs-t-h2","preview-title"],"components":[{"type":"textnode","content":"Event Schedule (Preview)"}]}]},{"type":"link","name":"Preview Link","classes":["gjs-t-link","preview-link"],"attributes":{"href":"page://qggXCAKgYbF5MnI4M"},"components":[{"type":"textnode","content":"\n        Full Schedule\n        "},{"type":"image","name":"Preview Arrow","resizable":{"ratioDefault":1},"classes":["preview-arrow"],"attributes":{"src":"https://api.iconify.design/lucide-arrow-right.svg?color=%2347b3ff","alt":"Arrow"}}]}]},{"name":"Preview Grid","classes":["preview-grid"],"components":[{"name":"Preview Day","classes":["preview-day"],"components":[{"type":"text","name":"Day Title","classes":["day-title"],"components":[{"type":"textnode","content":"Fri 27th"}]},{"tagName":"ul","name":"Day List","classes":["day-list"],"components":[{"tagName":"li","type":"text","name":"Day Item","components":[{"type":"textnode","content":"10:00 — Welcome & Intro"}]},{"tagName":"li","type":"text","name":"Day Item","components":[{"type":"textnode","content":"12:00 — Mesh Setup Workshop"}]},{"tagName":"li","type":"text","name":"Day Item","components":[{"type":"textnode","content":"15:00