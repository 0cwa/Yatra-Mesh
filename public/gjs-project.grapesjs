oad.svg?color=white","alt":"","loading":"lazy","id":"i84r4b"},"src":"https://api.iconify.design/lucide-download.svg?color=black"},{"tagName":"span","type":"text","attributes":{"id":"iojuyk"},"components":[{"type":"textnode","content":"Download"}]}]},{"type":"link","name":"Button Secondary","editable":false,"classes":["secondary-button"],"attributes":{"href":"#windows-tips","aria-label":"Windows relay tips","id":"iy9jdr"},"components":[{"type":"image","resizable":{"ratioDefault":1},"classes":["download-icon"],"attributes":{"src":"https://api.iconify.design/lucide-bolt.svg?color=white","alt":"","loading":"lazy","id":"i4q81d"}},{"tagName":"span","type":"text","attributes":{"id":"iviyp8"},"components":[{"type":"textnode","content":"Relay Tips"}]}]}]}]}]}]}]}]},{"type":"text","name":"Download Disclaimer","classes":["download-disclaimer"],"components":[{"type":"textnode","content":"Note: Desktop builds are less suggested for regular use. Prefer Android for a smooth, battery-optimized mesh experience."}]}]},{"tagName":"section","name":"FAQ Section","classes":["faq-section"],"components":[{"tagName":"h2","type":"heading","name":"FAQ Title","classes":["gjs-t-h2","faq-title"],"attributes":{"id":"i5wooj"},"components":[{"type":"textnode","content":"FAQ"}]},{"name":"FAQ Grid","classes":["faq-grid"],"components":[{"tagName":"details","name":"FAQ Item","classes":["group","faq-item"],"components":[{"tagName":"summary","name":"FAQ Summary","classes":["faq-summary"],"components":[{"tagName":"span","type":"text","name":"FAQ Question","classes":["faq-question"],"components":[{"type":"textnode","content":"How do I join the mesh?"}]},{"type":"image","name":"FAQ Chevron","resizable":{"ratioDefault":1},"classes":["group-open:rotate-180","faq-chevron"],"attributes":{"src":"https://api.iconify.design/lucide-chevron-down.svg?color=white","alt":""}}]},{"type":"text","name":"FAQ Answer","classes":["faq-answer"],"components":[{"type":"textnode","content":"\n              Install the Android app, enable bluetooth and wifi, then open Yatra Mesh. If a local hotspot or ad-hoc SSID appears (e.g., “Yatra Mesh”), connect to it. The app will announce and relay messages to nearby peers automatically.\n            "}]}]},{"tagName":"details","name":"FAQ Item","classes":["group","faq-item"],"components":[{"tagName":"summary","name":"FAQ Summary","classes":["faq-summary"],"components":[{"tagName":"span","type":"text","name":"FAQ Question","classes":["faq-question"],"components":[{"type":"textnode","content":"Is my data private?"}]},{"type":"image","name":"FAQ Icon","resizable":{"ratioDefault":1},"classes":["faq-icon"],"attributes":{"src":"https://api.iconify.design/lucide-lock.svg?color=white","alt":""}}]},{"type":"text","name":"FAQ Answer","classes":["faq-answer"],"components":[{"type":"textnode","content":"\n              Messages are relayed peer-to-peer and can be end-to-end encrypted when chatting directly. In mesh relays, metadata like relay hops may be visible to participating nodes. Avoid sensitive information; this is an experimental network.\n            "}]}]},{"tagName":"details","name":"FAQ Item","classes":["group","faq-item"],"components":[{"tagName":"summary","name":"FAQ Summary","classes":["faq-summary"],"components":[{"tagName":"span","type":"text","name":"FAQ Question","classes":["faq-question"],"components":[{"type":"textnode","content":"Why Android over desktop?"}]},{"type":"image","name":"FAQ Icon","resizable":{"ratioDefault":1},"classes":["faq-icon"],"attributes":{"src":"https://api.iconify.design/lucide-badge-check.svg?color=white","alt":""}}]},{"type":"text","name":"FAQ Answer","classes":["faq-answer"],"components":[{"type":"textnode","content":"\n              Android supports background scanning/relaying with better power profiles and direct bluetooth/wifi APIs. Desktop platforms require more permissions, have background limitations, and are best used as relay nodes.\n            "}]}]},{"tagName":"details","name":"FAQ Item","classes":["group","faq-item"],"components":[{"tagName":"summary","name":"FAQ Summary","classes":["faq-summary"],"components":[{"tagName":"span","type":"text","name":"FAQ Question","classes":["faq-question"],"components":[{"type":"textnode","content":"Troubleshooting tips"}]},{"type":"image","name":"FAQ Icon","resizable":{"ratioDefault":1},"classes":["faq-icon"],"attributes":{"src":"https://api.iconify.design/lucide-wrench.svg?color=white","alt":""}}]},{"type":"text","name":"FAQ Answer","classes":["faq-answer"],"components":[{"type":"textnode","content":"\n              Ensure bluetooth and wifi are enabled. Keep the app in foreground when first joining. Move closer to the crowd. If you lose messages, toggle airplane mode off/on to refresh radios, or restart the app to reannounce presence.\n            "}]}]}]}]}]},{"tagName":"section","name":"Schedule Page","classes":["schedule-page"],"attributes":{"id":"schedule"},"components":[{"tagName":"section","name":"Schedule Hero","classes":["schedule-hero"],"attributes":{"id":"i2k0t6"},"components":[{"name":"Schedule Header","classes":["schedule-header"],"attributes":{"id":"i0ta4f"},"components":[{"type":"heading","name":"Schedule Title","classes":["gjs-t-h1","schedule-title"],"attributes":{"id":"icdmu2"},"components":[{"type":"textnode","content":"Event Schedule"}]},{"type":"link","name":"Back Link","classes":["gjs-t-link","back-link"],"attributes":{"href":"#home","id":"i4tnln"},"components":[{"type":"textnode","content":"Back to Home"}]}]},{"tagName":"p","type":"text","name":"Schedule Subtitle","classes":["schedule-subtitle"],"components":[{"type":"textnode","content":"Four days of mesh experiments, workshops, and live relays. Bring your Android device and curiosity."}]}]},{"tagName":"section","name":"Schedule Content","classes":["schedule-content"],"components":[{"name":"Schedule Grid","classes":["schedule-grid"],"components":[{"name":"Day Card","classes":["day-card"],"components":[{"name":"Day Header","classes":["day-header"],"compone