                                  {
                                    "tagName": "p",
                                    "components": [
                                      {
                                        "type": "textnode",
                                        "content": "On first launch, a new Reticulum identity is automatically generated and saved to storage/identity"
                                      }
                                    ]
                                  }
                                ]
