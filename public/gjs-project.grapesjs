                              {
                                "tagName": "li",
                                "components": [
                                  {
                                    "tagName": "p",
                                    "components": [
                                      {
                                        "type": "textnode",
                                        "content": "Set your display name in My Identity panel (bottom left)"
                                      }
                                    ]
                                  }
                                ]
                              },
                              {
                                "tagName": "li",
                                "components": [
                                  {
                                    "tagName": "p",
                                    "components": [
                                      {
                                        "type": "textnode",
                                        "content": "Click Send Announce to broadcast your presence to the network"
                                      }
                                    ]
                                  }
                                ]
