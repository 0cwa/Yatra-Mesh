                            "classes": [
                              "gjs-t-h2"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "First Run Setup"
                              }
                            ]
                          },
                          {
                            "tagName": "ol",
                            "classes": [
                              "step-list"
