},{"name":"Session Content","classes":["session-content"],"components":[{"tagName":"span","type":"text","name":"Session Title","classes":["session-title"],"components":[{"type":"textnode","content":"11:00 • Community Clinic"}]},{"tagName":"p","type":"text","name":"Session Description","classes":["session-description"],"attributes":{"id":"is22gj"},"components":[{"type":"textnode","content":"\n    Bring issues, ideas, and tips. We’ll help you get the best experience together.\n  "}]}]}]},{"tagName":"li","name":"Session Item","classes":["session-item"],"components":[{"type":"image","name":"Session Icon","resizable":{"ratioDefault":1},"classes":["session-icon"],"attributes":{"src":"https://api.iconify.design/lucide-shield-check.svg?color=white","alt":""}},{"name":"Session Content","classes":["session-content"],"components":[{"tagName":"span","type":"text","name":"Session Title","classes":["session-title"],"components":[{"type":"textnode","content":"14:00 • Privacy in P2P"}]},{"tagName":"p","type":"text","name":"Session Description","classes":["session-description"],"components":[{"type":"textnode","content":"Talk and Q&A on encryption, metadata, and safe use in experimental meshes."}]}]}]},{"tagName":"li","name":"Session Item","classes":["session-item"],"components":[{"type":"image","name":"Session Icon","resizable":{"ratioDefault":1},"classes":["session-icon"],"attributes":{"src":"https://api.iconify.design/lucide-message-square.svg?color=white","alt":""}},{"name":"Session Content","classes":["session-content"],"components":[{"tagName":"span","type":"text","name":"Session Title","classes":["session-title"],"components":[{"type":"textnode","content":"17:30 • Mesh Stories"}]},{"tagName":"p","type":"text","name":"Session Description","classes":["session-description"],"components":[{"type":"textnode","content":"Share experiences from the field: what relayed, what failed, and what was magical."}]}]}]}]}]},{"name":"Day Card","classes":["day-card"],"components":[{"name":"Day Header","classes":["day-header"],"components":[{"type":"image","name":"Day Icon","resizable":{"ratioDefault":1},"classes":["day-icon"],"attributes":{"src":"https://api.iconify.design/lucide-calendar.svg?color=white","alt":""}},{"tagName":"span","type":"text","name":"Day Title","classes":["day-title"],"components":[{"type":"textnode","content":"Mon 2nd"}]}]},{"tagName":"ul","name":"Sessions List","classes":["sessions-list"],"attributes":{"id":"iyo5ko"},"components":[{"tagName":"li","classes":["session-item"],"attributes":{"id":"i4t4jg"},"components":[{"type":"image","resizable":{"ratioDefault":1},"classes":["session-icon"],"attributes":{"src":"https://api.iconify.design/lucide-antenna.svg?color=white","alt":"","id":"i3i22l"}},{"classes":["session-content"],"attributes":{"id":"iusmwd"},"components":[{"tagName":"span","type":"text","classes":["session-title"],"attributes":{"id":"ikz0ai"},"components":[{"type":"textnode","content":"13:30 • Field Test"}]},{"tagName":"p","type":"text","classes":["session-description"],"attributes":{"id":"ipsme2"},"components":[{"type":"textnode","content":"Outdoor mesh range test and public-space relays. Measure hops and latency."}]}]}]},{"tagName":"li","classes":["session-item"],"attributes":{"id":"iw877h"},"components":[{"type":"image","resizable":{"ratioDefault":1},"classes":["session-icon"],"attributes":{"src":"https://api.iconify.design/lucide-handshake.svg?color=white","alt":"","id":"incano"}},{"classes":["session-content"],"attributes":{"id":"iyz62v"},"components":[{"tagName":"span","type":"text","classes":["session-title"],"attributes":{"id":"iwbtlw"},"components":[{"type":"textnode","content":"16:30 • Closing Circle"}]},{"tagName":"p","type":"text","classes":["session-description"],"attributes":{"id":"i51llh"},"components":[{"type":"textnode","content":"Wrap-up, feedback, and where the mesh goes next. Thanks for relaying!"}]}]}]}]}]}]}]}]}]},{"tagName":"footer","name":"Footer","classes":["footer"],"components":[{"name":"Footer Container","classes":["footer-container"],"components":[{"name":"Footer Branding","classes":["footer-branding"],"components":[{"type":"image","name":"Footer Logo","resizable":{"ratioDefault":1},"classes":["footer-logo"],"attributes":{"src":"https://app.grapesjs.com/api/assets/random-image?query=%22psychedelic%20logo%20symbol%22&w=36&h=36","alt":"Yatra Mesh logo","loading":"lazy"}},{"name":"Footer Title Wrapper","classes":["footer-title-wrapper"],"components":[{"tagName":"span","type":"text","name":"Footer Title","classes":["footer-title"],"components":[{"type":"textnode","content":"Yatra Mesh"}]},{"tagName":"span","type":"text","name":"Footer Subtitle","classes":["footer-subtitle"],"components":[{"type":"textnode","content":"A living experimental network"}]}]}]},{"name":"Footer Links","classes":["footer-links"],"attributes":{"id":"izd24p"},"components":[{"tagName":"span","type":"text","classes":["footer-message"],"components":[{"type":"textnode","content":"Made with love by Free Open Source Developers who care about freedom."}]}]}]}]},{"type":"script","name":"Page Toggle Script","components":[{"type":"textnode","content":"\n    (function() {\n      const home = document.getElementById('home');\n      const schedule = document.getElementById('schedule');\n      const setView = () => {\n        const hash = window.location.hash || '#home';\n        if (hash === '#schedule') {\n          home.classList.remove('page-active');\n          home.classList.add('page-hidden');\n          schedule.classList.remove('page-hidden');\n          schedule.classList.add('page-active');\n        } else {\n          schedule.classList.remove('page-active');\n          schedule.classList.add('page-hidden');\n          home.classList.remove('page-hidden');\n          home.classList.add('page-active');\n        }\n      };\n      window.addEventListener('hashchange', setView);\n      setView();\n    })();\n  "}]}],"doctype":"<!DOCTYPE html>","head":{"type":"head","components":[{"tagName":"meta","void":true,"attributes":{"charset":"utf-8"}},{"tagName":"meta","void":true,"attributes":{"name":"viewport","content":"width=device-width, initial-scale=1"}},{"tagName":"title","type":"text","name":"Document Title","attributes":{"id":"isak"},"components":[{"type":"textnode","content":"Yatra Mesh • Psychedelic Mesh"}]},{"tagName":"link","name":"Google Fonts Link","void":true,"attributes":{"href":"https://fonts.googleapis.com/css2?family=Monoton&family=Inter:wght@400;600;700&display=swap","rel":"stylesheet"}}]},"docEl":{"tagName":"html","attributes":{"lang":"en"}}},"id":"3XEuPzxBNajMINFl","minHeight":"500px"}],"id":"UOOELHATDJU2Z5UT"},{"name":"Yatra Mesh Schedule","frames":[{"component":{"type":"wrapper","name":"Body","classes":["gjs-t-body","body"],"components":[{"tagName":"header","name":"Navbar Wrapper","classes":["navbar-wrapper"],"components":[{"name":"Navbar Container","classes":["navbar-container"],"components":[{"type":"link","name":"Navbar Brand","editable":false,"classes":["group","navbar-brand"],"attributes":{"href":"page://UOOELHATDJU2Z5UT"},"components":[{"name":"Brand Icon","classes":["group-hover:scale-105","brand-icon"]},{"name":"Brand Text","classes":["brand-text"],"components":[{"tagName":"span","type":"text","name":"Brand Name","classes":["gjs-t-h2","brand-name"],"components":[{"type":"textnode","content":"Yatra Mesh"}]},{"tagName":"span","type":"text","name":"Brand Tagline","classes":["brand-tagline"],"components":[{"type":"textnode","content":"Peer-to-peer messaging portal"}]}]}]},{"tagName":"nav","name":"Navbar Links","classes":["navbar-links"],"components":[{"type":"link","name":"Navbar Link","classes":["gjs-t-link","navbar-link"],"attributes":{"href":"#connect"},"components":[{"type":"image","name":"Link Icon","resizable":{"ratioDefault":1},"classes":["link-icon"],"attributes":{"src":"https://api.iconify.design/lucide-wifi.svg?color=%2347b3ff","alt":"WiFi Icon"}},{"type":"textnode","content":"\n          Connect\n        "}]},{"type":"link