                  {
                    "tagName": "div",
                    "classes": [
                      "help-content"
                    ],
                    "components": [
                      {
                        "id": "what-is-meshchat",
                        "tagName": "section",
                        "components": [
                          {
                            "tagName": "h2",
                            "classes": [
                              "gjs-t-h2"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "What is Reticulum MeshChat?"
                              }
                            ]
                          },
                          {
                            "tagName": "p",
                            "classes": [
                              "gjs-t-body"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Reticulum MeshChat is a cross-platform desktop client for Reticulum mesh networks. It provides a web-based interface for sending LXMF messages, making voice calls, and browsing Nomad Network pages."
                              }
                            ]
                          },
                          {
                            "tagName": "p",
                            "classes": [
                              "gjs-t-body"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Available for Windows, macOS, and Linux. Can run as a standalone Electron app or directly from source using Python/Node.js."
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "id": "installation",
                        "tagName": "section",
                        "components": [
                          {
                            "tagName": "h2",
                            "classes": [
                              "gjs-t-h2"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Installation"
                              }
                            ]
                          },
                          {
                            "tagName": "h3",
                            "classes": [
                              "gjs-t-h2"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Pre-built Binaries"
                              }
                            ]
                          },
                          {
                            "tagName": "p",
                            "classes": [
                              "gjs-t-body"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Download the latest release for your platform from the GitHub releases page. Extract and run the executable."
                              }
                            ]
                          },
                          {
                            "tagName": "h3",
                            "classes": [
                              "gjs-t-h2"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Running from Source"
                              }
                            ]
                          },
                          {
                            "tagName": "pre",
                            "classes": [
                              "code-block"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "# Clone repository\ngit clone https://github.com/liamcottle/reticulum-meshchat\ncd reticulum-meshchat\nnpm install\nnpm run build-frontend\npip install -r requirements.txt\npython meshchat.py"
                              }
                            ]
                          },
                          {
                            "tagName": "p",
                            "classes": [
                              "gjs-t-body"
                            ],
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Access the web interface at http://localhost:8000 after starting."
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "id": "first-run",
                        "tagName": "section",
                        "components": [
                          {
