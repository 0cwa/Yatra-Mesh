                          }
                        ]
                      },
                      {
                        "tagName": "p",
                        "type": "text",
                        "classes": [
                          "help-subtitle"
                        ],
                        "components": [
                          {
                            "type": "textnode",
                            "content": "Everything you need to know about using Yatra Mesh"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "tagName": "section",
                    "name": "Getting Started",
                    "classes": [
                      "help-section",
                      "about-text-card"
                    ],
                    "components": [
                      {
                        "tagName": "h2",
                        "type": "heading",
                        "classes": [
                          "gjs-t-h2"
                        ],
                        "components": [
                          {
                            "type": "textnode",
                            "content": "Getting Started"
                          }
                        ]
                      },
                      {
                        "tagName": "ol",
                        "classes": [
                          "help-steps"
                        ],
                        "components": [
                          {
                            "tagName": "li",
                            "components": [
                              {
                                "tagName": "strong",
                                "components": [
                                  {
                                    "type": "textnode",
                                    "content": "Download the App"
                                  }
                                ]
                              },
                              {
                                "type": "textnode",
                                "content": " - Get the Android APK from the Downloads section"
                              }
                            ]
                          },
                          {
                            "tagName": "li",
                            "components": [
                              {
                                "tagName": "strong",
                                "components": [
                                  {
                                    "type": "textnode",
                                    "content": "Install the APK"
                                  }
                                ]
                              },
                              {
                                "type": "textnode",
                                "content": " - Enable \"Install from unknown sources\" in your Android settings"
                              }
                            ]
                          },
                          {
                            "tagName": "li",
                            "components": [
                              {
                                "tagName": "strong",
                                "components": [
                                  {
                                    "type": "textnode",
                                    "content": "Create Your Identity"
                                  }
                                ]
                              },
                              {
                                "type": "textnode",
                                "content": " - The app will generate a unique anonymous identity for you"
                              }
                            ]
                          },
                          {
                            "tagName": "li",
                            "components": [
                              {
                                "tagName": "strong",
                                "components": [
                                  {
                                    "type": "textnode",
                                    "content": "Send an Announce"
                                  }
                                ]
                              },
                              {
                                "type": "textnode",
                                "content": " - Let others on the mesh know you are here"
                              }
                            ]
                          },
                          {
                            "tagName": "li",
                            "components": [
                              {
                                "tagName": "strong",
                                "components": [
                                  {
                                    "type": "textnode",
                                    "content": "Start Messaging"
                                  }
                                ]
                              },
                              {
                                "type": "textnode",
                                "content": " - Discover peers and send encrypted messages"
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "tagName": "section",
                    "name": "FAQ Section",
                    "classes": [
                      "help-section",
                      "about-text-card"
                    ],
                    "components": [
                      {
                        "tagName": "h2",
                        "type": "heading",
                        "classes": [
                          "gjs-t-h2"
                        ],
                        "components": [
                          {
                            "type": "textnode",
                            "content": "Frequently Asked Questions"
                          }
                        ]
                      },
                      {
                        "tagName": "dl",
                        "classes": [
                          "faq-list"
                        ],
                        "components": [
                          {
                            "tagName": "dt",
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Do I need internet to use Yatra Mesh?"
                              }
                            ]
                          },
                          {
                            "tagName": "dd",
                            "components": [
                              {
                                "type": "textnode",
                                "content": "No! Yatra Mesh works completely offline using WiFi and Bluetooth to create a mesh network. No internet, cell towers, or central servers required."
                              }
                            ]
                          },
                          {
                            "tagName": "dt",
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Is my data private?"
                              }
                            ]
                          },
                          {
                            "tagName": "dd",
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Yes. All messages are end-to-end encrypted. No accounts, no tracking, no central servers. Your identity lives only on your device."
                              }
                            ]
                          },
                          {
                            "tagName": "dt",
                            "components": [
                              {
                                "type": "textnode",
                                "content": "How far can messages travel?"
                              }
                            ]
                          },
                          {
                            "tagName": "dd",
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Messages hop through peers - the more nodes running, the farther they can travel. With enough relays, messages can cross the entire venue."
                              }
                            ]
                          },
                          {
                            "tagName": "dt",
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Why Android only?"
                              }
                            ]
                          },
                          {
                            "tagName": "dd",
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Android provides the best experience for background relaying, battery optimization, and Bluetooth access. Desktop apps are experimental."
                              }
                            ]
                          },
                          {
                            "tagName": "dt",
                            "components": [
                              {
                                "type": "textnode",
                                "content": "What is background relaying?"
                              }
                            ]
                          },
                          {
                            "tagName": "dd",
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Running the app with screen off allows your device to forward messages for others. This is essential for a healthy mesh network."
                              }
                            ]
                          },
                          {
                            "tagName": "dt",
                            "components": [
                              {
                                "type": "textnode",
                                "content": "How do I share my identity?"
                              }
                            ]
                          },
                          {
                            "tagName": "dd",
                            "components": [
                              {
                                "type": "textnode",
                                "content": "Use the built-in QR code scanner/generator to share your identity with others. They can scan your code to message you."
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "tagName": "section",
                    "name": "Troubleshooting",
                    "classes": [
                      "help-section",
                      "about-text-card"
                    ],
                    "components": [
                      {
                        "tagName": "h2",
                        "type": "heading",
                        "classes": [
                          "gjs-t-h2"
                        ],
                        "components": [
                          {
                            "type": "textnode",
                            "content": "Troubleshooting"
                          }
                        ]
                      },
                      {
                        "tagName": "ul",
                        "classes": [
                          "about-feature-list"
                        ],
                        "components": [
                          {
                            "tagName": "li",
                            "classes": [
                              "about-feature-item"
                            ],
                            "components": [
                              {
                                "tagName": "strong",
                                "components": [
                                  {
                                    "type": "textnode",
                                    "content": "Can't see peers?"
                                  }
                                ]
                              },
                              {
                                "type": "textnode",
                                "content": " Make sure WiFi and Bluetooth are enabled. Send an announce to be visible to others."
                              }
                            ]
                          },
                          {
                            "tagName": "li",
                            "classes": [
                              "about-feature-item"
                            ],
                            "components": [
                              {
                                "tagName": "strong",
                                "components": [
                                  {
                                    "type": "textnode",
                                    "content": "Messages not delivering?"
                                  }
                                ]
                              },
                              {
                                "type": "textnode",
                                "content": " Check that both sender and receiver have sent announces. More relay nodes help."
                              }
                            ]
                          },
                          {
                            "tagName": "li",
                            "classes": [
                              "about-feature-item"
                            ],
                            "components": [
                              {
                                "tagName": "strong",
                                "components": [
                                  {
                                    "type": "textnode",
                                    "content": "Installation blocked?"
                                  }
                                ]
                              },
                              {
                                "type": "textnode",
                                "content": " Go to Settings > Security > Install unknown apps and enable for your file manager."
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "tagName": "section",
                    "name": "About The Apps",
                    "classes": [
                      "help-section",
                      "about-text-card"
                    ],
                    "components": [
                      {
                        "tagName": "h2",
                        "type": "heading",
                        "classes": [
                          "gjs-t-h2"
                        ],
                        "components": [
                          {
                            "type": "textnode",
                            "content": "About The Apps"
                          }
                        ]
                      },
                      {
                        "tagName": "p",
                        "components": [
                          {
                            "type": "textnode",
                            "content": "Yatra Mesh apps are built on open source projects:"
                          }
                        ]
                      },
                      {
                        "classes": [
                          "about-feature-list"
                        ],
                        "components": [
                          {
                            "classes": [
                              "about-feature-item"
                            ],
                            "components": [
                              {
                                "type": "image",
                                "resizable": {
                                  "ratioDefault": 1
                                },
                                "attributes": {
                                  "src": "/columba-logo.svg",
                                  "alt": "Columba",
                                  "style": "height:24px;vertical-align:middle;margin-right:8px;"
                                }
                              },
                              {
                                "tagName": "strong",
                                "components": [
                                  {
                                    "type": "textnode",
                                    "content": "Mobile (Android)"
                                  }
                                ]
                              },
                              {
                                "type": "textnode",
                                "content": " - Built on Columba, a native Android messaging app using Bluetooth LE, TCP, or RNode (LoRa) over LXMF and Reticulum"
                              }
                            ]
                          },
                          {
                            "classes": [
                              "about-feature-item"
                            ],
                            "components": [
                              {
                                "type": "image",
                                "resizable": {
                                  "ratioDefault": 1
                                },
                                "attributes": {
                                  "src": "/meshchat-logo.png",
                                  "alt": "MeshChat",
                                  "style": "height:24px;vertical-align:middle;margin-right:8px;"
                                }
                              },
                              {
                                "tagName": "strong",
                                "components": [
                                  {
                                    "type": "textnode",
                                    "content": "Desktop"
                                  }
                                ]
                              },
                              {
                                "type": "textnode",
                                "content": " - Built on MeshChat, a simple mesh network communications app powered by Reticulum Network Stack"
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                ]
              },
              {
                "tagName": "footer",
                "name": "Footer",
                "classes": [
                  "footer"
                ],
                "components": [
                  {
                    "tagName": "p",
                    "components": [
                      {
                        "type": "textnode",
                        "content": "\u00a9 Yatra Mesh \u2014 Experimental Captive Portal"
                      }
                    ]
                  }
                ]
              }
            ],
