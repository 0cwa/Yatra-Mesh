              {
                "type": "script",
                "name": "Page Toggle Script",
                "components": [
                  {
                    "type": "textnode",
                    "content": "\n    (function() {\n      const home = document.getElementById('home');\n      const schedule = document.getElementById('schedule');\n      const setView = () => {\n        const hash = window.location.hash || '#home';\n        if (hash === '#schedule') {\n          home.classList.remove('page-active');\n          home.classList.add('page-hidden');\n          schedule.classList.remove('page-hidden');\n          schedule.classList.add('page-active');\n        } else {\n          schedule.classList.remove('page-active');\n          schedule.classList.add('page-hidden');\n          home.classList.remove('page-hidden');\n          home.classList.add('page-active');\n        }\n      };\n      window.addEventListener('hashchange', setView);\n      setView();\n    })();\n  "
                  }
                ]
              }
            ],
